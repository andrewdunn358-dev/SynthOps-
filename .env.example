# SynthOps Environment Configuration Template
# Copy this file to .env and fill in your values

# ============================================
# SECURITY (Auto-generated on install)
# ============================================
JWT_SECRET=your-jwt-secret-here
ENCRYPTION_KEY=your-encryption-key-here

# ============================================
# APPLICATION
# ============================================
FRONTEND_URL=http://localhost

# ============================================
# TACTICAL RMM INTEGRATION
# ============================================
TACTICAL_RMM_API_URL=https://api.your-trmm.com/
TACTICAL_RMM_API_KEY=your-trmm-api-key

# ============================================
# ZAMMAD INTEGRATION
# ============================================
ZAMMAD_API_URL=https://help.yourcompany.com
ZAMMAD_API_TOKEN=your-zammad-token

# ============================================
# MESHCENTRAL REMOTE ACCESS
# ============================================
MESHCENTRAL_URL=https://mesh.yourcompany.com

# ============================================
# VAULTWARDEN PASSWORD MANAGER
# ============================================
VAULTWARDEN_URL=http://localhost:8082
VAULTWARDEN_ADMIN_TOKEN=

# ============================================
# NOTIFICATIONS
# ============================================
# Microsoft Teams Webhook URL
TEAMS_WEBHOOK_URL=

# SendGrid (optional)
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=alerts@yourcompany.com

# ============================================
# SYNC SETTINGS
# ============================================
SYNC_INTERVAL_MINUTES=15

# ============================================
# AI ASSISTANT (Sophie)
# ============================================
# Leave empty to use Emergent LLM Key (recommended)
EMERGENT_LLM_KEY=

# ============================================
# DATABASE ADMIN (optional)
# ============================================
MONGO_EXPRESS_USER=admin
MONGO_EXPRESS_PASSWORD=change-me

# ============================================
# ADVANCED SETTINGS
# ============================================
CORS_ORIGINS=*
