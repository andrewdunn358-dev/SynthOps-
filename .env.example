# SynthOps Configuration
# Copy this file to .env and fill in your values

# ===========================================
# REQUIRED SETTINGS
# ===========================================

# Your domain (used for frontend URL and CORS)
FRONTEND_URL=https://ops.yourdomain.com

# Security keys (CHANGE THESE IN PRODUCTION!)
JWT_SECRET=change-this-to-a-long-random-string-at-least-32-chars
ENCRYPTION_KEY=change-this-to-32-character-key!

# ===========================================
# TACTICAL RMM INTEGRATION
# ===========================================

# Your Tactical RMM API URL
TACTICAL_RMM_API_URL=https://api.yourcompany.com/

# Your Tactical RMM API Key
TACTICAL_RMM_API_KEY=your-trmm-api-key-here

# ===========================================
# ZAMMAD INTEGRATION (Optional)
# ===========================================

# Your Zammad URL
ZAMMAD_API_URL=https://tickets.yourcompany.com

# Your Zammad API Token
ZAMMAD_API_TOKEN=your-zammad-token-here

# ===========================================
# SYNC SETTINGS
# ===========================================

# How often to sync TRMM and Zammad (in minutes)
SYNC_INTERVAL_MINUTES=15

# ===========================================
# ADMIN UI (Optional)
# ===========================================

# Mongo Express credentials (database admin UI)
MONGO_EXPRESS_USER=admin
MONGO_EXPRESS_PASSWORD=change-this-password

# ===========================================
# VAULTWARDEN (Optional password manager)
# ===========================================

# Domain for Vaultwarden
VAULTWARDEN_DOMAIN=https://vault.yourdomain.com

# Admin token for Vaultwarden (leave empty to disable admin panel)
VAULTWARDEN_ADMIN_TOKEN=

# ===========================================
# AI ASSISTANT (Optional)
# ===========================================

# Emergent LLM Key for Sophie AI assistant
EMERGENT_LLM_KEY=
